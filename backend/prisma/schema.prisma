model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  role     String @default("ADMIN")
  nama     String
}

// 2. KRITERIA AHP (Kriteria Utama)
model Kriteria {
  kode       String  @id              // Contoh: C1, C2
  nama       String                   // Nama kriteria (Sosiometri, dll)
  keterangan String? @db.Text         // Deskripsi
  bobot      Float   @default(0)      // Bobot Global (Eigenvector dari C)
  
  penilaian  Penilaian[]
}

// 3. SUB-KRITERIA (Tingkat Risiko T1-T5 sebagai standar ukur absolut)
model SubKriteria {
  kode        String  @id             // Contoh: T1, T2
  nama_sub    String                  // Contoh: Sangat Parah, Aman
  eigen       Float   @default(0)
  bobot_ideal Float                   // Bobot Idealisasi (Contoh: 1.0000, 0.6290)
  keterangan  String? @db.Text
  
  penilaian   Penilaian[]
}

// 4. DATA SISWA (Alternatif)
model Siswa {
  id          Int      @id @default(autoincrement())
  nisn        String   @unique
  nama        String
  kelas       String
  gender      String
  
  // Tempat menyimpan rekam jejak hasil akhir SPK
  nilai_akhir Float?   
  kategori    String? 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  penilaian   Penilaian[]
}

// 5. PENILAIAN (Menggantikan pola angka murni)
model Penilaian {
  id               Int    @id @default(autoincrement())
  siswa_id         Int
  kriteria_kode    String
  subkriteria_kode String

  // Relasi ke tabel-tabel utama
  siswa       Siswa       @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  kriteria    Kriteria    @relation(fields: [kriteria_kode], references: [kode], onDelete: Cascade)
  subkriteria SubKriteria @relation(fields: [subkriteria_kode], references: [kode], onDelete: Cascade)

  // Constraint: 1 siswa hanya bisa memiliki 1 kondisi (T) per kriteria (C)
  @@unique([siswa_id, kriteria_kode]) 
}